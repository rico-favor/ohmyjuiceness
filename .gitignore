# Secrets — never commit
.env
.env.*

# OS / editor
.DS_Store

# QA artifacts (browser automation screenshots)
.playwright-mcp/
*.jpeg
*.jpg
*.png
!logo/*.png

# Local DB / settings backups (never commit)
backups/

# Graphify (generated knowledge-graph outputs — rebuild from source)
graphify-out/
.graphify_*.json
.graphify_*.txt

# Symlink created during graphify run (build/ is the real directory)
src

# Superpowers brainstorm companion
.superpowers/

# Preview assets are committed (processed deliverables)
!build/preview/assets/img/**/*.jpg
!build/preview/assets/img/**/*.jpeg
!build/preview/assets/img/**/*.png
!build/preview/assets/img/**/*.webp
# ...except QA/intermediate artifacts, which stay untracked
build/preview/assets/img/contact-sheet.jpg
build/preview/assets/img/**/tmp/**
build/preview/assets/img/**/candidates/**
